Form Function SchoolSpell(String aSchool, Int aiSlot) Global
    If aSchool == "Destruction"
        If aiSlot == 0
            Return Game.GetFormFromFile(0x00012fcd, "Skyrim.esm") ; Flames
        EndIf
        If aiSlot == 1
            Return Game.GetFormFromFile(0x0002dd2a, "Skyrim.esm") ; Sparks
        EndIf
    EndIf
    If aSchool == "Conjuration"
        If aiSlot == 0
            Return Game.GetFormFromFile(0x000640b6, "Skyrim.esm") ; Conjure Familiar
        EndIf
        If aiSlot == 1
            Return Game.GetFormFromFile(0x0007e8e1, "Skyrim.esm") ; Raise Zombie
        EndIf
    EndIf
    If aSchool == "Illusion"
        If aiSlot == 0
            Return Game.GetFormFromFile(0x0004dee8, "Skyrim.esm") ; Courage
        EndIf
        If aiSlot == 1
            Return Game.GetFormFromFile(0x0004deeb, "Skyrim.esm") ; Fury
        EndIf
    EndIf
    If aSchool == "Alteration"
        If aiSlot == 0
            Return Game.GetFormFromFile(0x0005ad5c, "Skyrim.esm") ; Oakflesh
        EndIf
        If aiSlot == 1
            Return Game.GetFormFromFile(0x00043324, "Skyrim.esm") ; Candlelight
        EndIf
    EndIf
    If aSchool == "Restoration"
        If aiSlot == 0
            Return Game.GetFormFromFile(0x00012fcc, "Skyrim.esm") ; Healing
        EndIf
        If aiSlot == 1
            Return Game.GetFormFromFile(0x00013018, "Skyrim.esm") ; Lesser Ward
        EndIf
    EndIf
    Return None
EndFunction

