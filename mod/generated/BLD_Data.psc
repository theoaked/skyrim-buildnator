String Function FactionHint(String aKey) Global
    If aKey == "The Companions"
        Return "Walk into Jorrvaskr in Whiterun and ask to join."
    EndIf
    If aKey == "College of Winterhold"
        Return "Pass the gate test at the bridge to Winterhold's College."
    EndIf
    If aKey == "Thieves Guild"
        Return "Find Brynjolf in Riften's marketplace and play along."
    EndIf
    If aKey == "Dark Brotherhood"
        Return "Murder an innocent, then sleep. They will find you."
    EndIf
    If aKey == "Imperial Legion"
        Return "Report to Legate Rikke in Castle Dour, Solitude."
    EndIf
    If aKey == "Stormcloaks"
        Return "Seek Ulfric Stormcloak in the Palace of the Kings, Windhelm."
    EndIf
    If aKey == "Dawnguard"
        Return "Travel to Fort Dawnguard, southeast of Riften, and speak to Isran."
    EndIf
    If aKey == "Volkihar Vampires"
        Return "Complete Dawnguard's opening quests and accept Harkon's gift."
    EndIf
    If aKey == "Bards College"
        Return "Ask Viarmo in Solitude to join the Bards College."
    EndIf
    If aKey == "None"
        Return "You walk alone. No hall, no oath, no master."
    EndIf
    Return "You walk alone."
EndFunction

